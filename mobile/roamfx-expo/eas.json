{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ROAMFX_URL": "http://192.168.1.19:3000"
      }
    },
    "hosted-preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ROAMFX_URL": "https://roamfx-frontend.pages.dev"
      }
    },
    "ios-simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_ROAMFX_URL": "http://192.168.1.19:3000"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_ROAMFX_URL": "https://roamfx-frontend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
